{
    "name": "Doughskin",
    "description": "Eating baked goods increases your maximum health and size!",
    "badges": [
        {
            "type": "origins:tooltip",
            "text": "Increments by 1 heart and 0.25 meters. Consuming increases, taking damage decreases.",
            "sprite": "origins:textures/gui/badge/info.png"
        },
        {
            "type": "origins:tooltip",
            "text": "Start with 5 health and 0.25 meters tall. Maximum is 20 hearts and 4 meters tall!",
            "sprite": "origins:textures/gui/badge/info.png"
        },
        {
            "type": "origins:tooltip",
            "text": "You have the chance to drop a cookie upon taking damage!",
            "sprite": "origins:textures/gui/badge/info.png"
        }
    ],
    "type": "origins:multiple",
    "size_resource": {
        "type": "origins:resource",
        "min": 0,
        "max": 15,
        "start_value": 0
    },
    "increase": {
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_increase_cooldown",
            "comparison": "==",
            "compare_to": 0
        },
        "type": "origins:action_on_item_use",
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:change_resource",
                    "resource": "*:*_size_resource",
                    "change": 1,
                    "operation": "add"
                },
                {
                    "type": "origins:trigger_cooldown",
                    "power": "*:*_increase_cooldown"
                }
            ]
        },
        "item_condition": {
            "type": "origins:ingredient",
            "ingredient": {
                "tag": "msmp_origins:gingerborne_consumable"
            }
        },
        "trigger": "finish",
        "priority": 0
    },
    "increase_cooldown": {
        "type": "origins:cooldown",
        "cooldown": 2400
    },
    "decrease": {
        "type": "origins:action_when_hit",
        "bientity_action": {
            "type": "origins:target_action",
            "action": {
                "type": "origins:and",
                "actions": [
                    {
                        "type": "origins:change_resource",
                        "resource": "*:*_size_resource",
                        "change": -1,
                        "operation": "add"
                    },
                    {
                        "type": "origins:chance",
                        "chance": 0.6,
                        "action": {
                            "type": "origins:execute_command",
                            "command": "loot spawn ~ ~ ~ loot msmp_origins:gingerborne_drops"
                        }
                    }
                ]
            }
        },
        "cooldown": 400
    },
    "size_def": {
        "type": "origins:action_on_callback",
        "entity_action_chosen": {
            "type": "origins:execute_command",
            "command": "scale persist set true @s"
        },
        "execute_chosen_when_orb": true,
        "entity_action_lost": {
            "type": "origins:execute_command",
            "command": "scale reset @s"
        }
    },
