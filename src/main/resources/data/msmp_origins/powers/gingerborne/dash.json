{
    "name": "Brave Dash",
    "description": "Dash forward and deal area damage to all enemies in your way!",
    "type": "origins:multiple",
    "dash": {
        "type": "origins:active_self",
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:spawn_particles",
                    "particle": "minecraft:poof",
                    "count": 20,
                    "speed": 0.1,
                    "offset_y": -0.5
                },
                {
                    "type": "origins:add_velocity",
                    "y": 0.5,
                    "z": 4,
                    "space": "local",
                    "client": true,
                    "server": true
                },
                {
                    "type": "origins:play_sound",
                    "sound": "minecraft:entity.wither.shoot",
                    "volume": 0.5,
                    "pitch": 0.65
                },
                {
                    "type": "origins:delay",
                    "action": {
                        "type": "origins:execute_command",
                        "command": "tag @s add msmp.gingerborne.dashing"
                    },
                    "ticks": 2
                }
            ]
        },
        "cooldown": 600,
        "hud_render": {
            "should_render": true,
            "sprite_location": "origins:textures/gui/community/huang/resource_bar_01.png",
            "bar_index": 20
        },
        "key": "primary"
    },
    "tick": {
        "type": "origins:action_over_time",
        "interval": 1,
        "entity_action": {
            "type": "origins:if_else",
            "condition": {
                "type": "origins:command",
                "command": "execute if entity @s[tag=msmp.gingerborne.dashing]",
                "comparison": ">=",
                "compare_to": 1
            },
            "if_action": {
                "type": "origins:and",
                "actions": [
                    {
                        "type": "origins:spawn_particles",
                        "particle": "minecraft:flame",
                        "count": 30,
                        "speed": 0,
                        "spread": {
                            "x": 0.5,
                            "y": 0.75,
                            "z": 0.5
                        }
                    },
                    {
                        "type": "origins:area_of_effect",
                        "radius": 3,
                        "bientity_action": {
                            "type": "origins:and",
                            "actions": [
                                {
                                    "type": "origins:damage",
                                    "amount": 3,
                                    "damage_type": "minecraft:player_attack"
                                },
                                {
                                    "type": "origins:add_velocity",
                                    "y": 0.75,
                                    "z": 2,
                                    "client": true,
                                    "server": true
                                }
                            ]
                        }
                    },
                    {
                        "type": "origins:if_else",
                        "condition": {
                            "type": "origins:on_block"
                        },
                        "if_action": {
                            "type": "origins:execute_command",
                            "command": "tag @s remove msmp.gingerborne.dashing"
                        }
                    }
                ]
            }
        }
    }
}