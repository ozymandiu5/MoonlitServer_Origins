{
  "name": "Fear of Heights",
  "description": "Gain Weakness when above Y=100, and Nausea when above Y=200.",
  "type": "origins:action_over_time",
  "interval": 20,
  "entity_action": {
    "type": "origins:and",
    "actions": [
      {
        "type": "origins:if_else",
        "condition": {
          "type": "origins:command",
          "command": "data get entity @s Pos[1]",
          "comparison": ">=",
          "compare_to": 100
        },
        "if_action": {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:weakness",
            "duration": 60,
            "amplifier": 0,
            "is_ambient": true,
            "show_particles": false,
            "show_icon": true
          }
        }
      },
      {
        "type": "origins:if_else",
        "condition": {
          "type": "origins:command",
          "command": "data get entity @s Pos[1]",
          "comparison": ">=",
          "compare_to": 200
        },
        "if_action": {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:nausea",
            "duration": 200,
            "amplifier": 0,
            "is_ambient": true,
            "show_particles": false,
            "show_icon": true
          }
        }
      }
    ]
  }
}