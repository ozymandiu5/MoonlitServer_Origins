{
    "name": "Imprisioning Darkness",
    "description": "You get Slowness and do 15% less damage when exposed to the sun.\nBeing in the sun for any longer than 5 minutes will set you on fire!",
    "badges": [
        {
            "type": "origins:tooltip",
            "text": "The timer decreases at the same rate, so if you catch fire, you have to stay out of the sun for another five minutes!",
            "sprite": "origins:textures/gui/badge/info.png"
        },
        {
            "type": "origins:tooltip",
            "text": "You'll get more slowness for every minute you spend in the sun. (except for the 5th minute)",
            "sprite": "origins:textures/gui/badge/info.png"
        },
        {
            "type": "origins:tooltip",
            "text": "Fire damage is 3x as more potent!",
            "sprite": "origins:textures/gui/badge/info.png"
        }
    ],
    "type": "origins:multiple",
    "damage": {
        "condition": {
            "type": "origins:exposed_to_sun"
        },
        "type": "origins:conditioned_attribute",
        "modifier": {
            "attribute": "minecraft:generic.attack_damage",
            "operation": "multiply_total",
            "value": -0.15
        },
        "tick_rate": 20,
        "update_health": true
    },
    "def": {
        "type": "origins:action_on_callback",
        "execute_chosen_when_orb": true,
        "entity_action_gained": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:execute_command",
                    "command": "scoreboard objectives add msmp.veilbound.sun_timer dummy"
                },
                {
                    "type": "origins:delay",
                    "action": {
                        "type": "origins:execute_command",
                        "command": "scoreboard players set @s msmp.veilbound.sun_timer 0"
                    },
                    "ticks": 1
                }
            ]
        }
    },
    "tick": {
        "type": "origins:action_over_time",
        "interval": 20,
        "entity_action": {
            "type": "origins:if_else_list",
            "actions": [
                {
                    "condition": {
                        "type": "origins:and",
                        "conditions": [
                            {
                                "type": "origins:exposed_to_sun"
                            },
                            {
                                "type": "origins:scoreboard",
                                "name": "@s",
                                "objective": "msmp.veilbound.sun_timer",
                                "comparison": "<=",
                                "compare_to": 299
                            },
                            {
                                "type": "origins:command",
                                "command": "execute unless entity @s[tag=msmp.veilbound.veil]",
                                "comparison": ">=",
                                "compare_to": 1
                            },
                            {
                                "inverted": true,
                                "type": "origins:gamemode",
                                "gamemode": "creative"
                            }
                        ]
                    },
                    "action": {
                        "type": "origins:execute_command",
                        "command": "scoreboard players add @s msmp.veilbound.sun_timer 1"
                    }
                },
                {
                    "condition": {
                        "type": "origins:and",
                        "conditions": [
                            {
                                "type": "origins:scoreboard",
                                "name": "@s",
                                "objective": "msmp.veilbound.sun_timer",
                                "comparison": ">=",
                                "compare_to": 1
                            },
                            {
                                "type": "origins:or",
                                "conditions": [
                                    {
                                        "inverted": true,
                                        "type": "origins:exposed_to_sun"
                                    },
                                    {
                                        "type": "origins:command",
                                        "command": "execute if entity @s[tag=msmp.veilbound.veil]",
                                        "comparison": ">=",
                                        "compare_to": 1
                                    }
                                ]
                            }
                        ]
                    },
                    "action": {
                        "type": "origins:execute_command",
                        "command": "scoreboard players remove @s msmp.veilbound.sun_timer 1"
                    }
                },
                {
                    "condition": {
                        "type": "origins:and",
                        "conditions": [
                            {
                                "type": "origins:exposed_to_sun"
                            },
                            {
                                "type": "origins:scoreboard",
                                "name": "@s",
                                "objective": "msmp.veilbound.sun_timer",
                                "comparison": "==",
                                "compare_to": 300
                            },
                            {
                                "type": "origins:command",
                                "command": "execute unless entity @s[tag=msmp.veilbound.veil]",
                                "comparison": ">=",
                                "compare_to": 1
                            }
                        ]
                    },
                    "action": {
                        "type": "origins:set_on_fire",
                        "duration": 4
                    }
                }
            ]
        }
    },
    "tick_effects": {
        "condition": {
            "type": "origins:and",
            "conditions": [
                {
                    "type": "origins:exposed_to_sun"
                },
                {
                    "type": "origins:command",
                    "command": "execute unless entity @s[tag=msmp.veilbound.veil]",
                    "comparison": ">=",
                    "compare_to": 1
                }
            ]
        },
        "type": "origins:action_over_time",
        "interval": 1,
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:if_else",
                    "condition": {
                        "type": "origins:command",
                        "command": "execute if score @s msmp.veilbound.sun_timer matches 1..60",
                        "comparison": ">=",
                        "compare_to": 1
                    },
                    "if_action": {
                        "type": "origins:apply_effect",
                        "effect": {
                            "effect": "minecraft:slowness",
                            "duration": 100,
                            "amplifier": 0,
                            "is_ambient": true,
                            "show_particles": false,
                            "show_icon": true
                        }
                    }
                },
                {
                    "type": "origins:if_else",
                    "condition": {
                        "type": "origins:command",
                        "command": "execute if score @s msmp.veilbound.sun_timer matches 61..120",
                        "comparison": ">=",
                        "compare_to": 1
                    },
                    "if_action": {
                        "type": "origins:apply_effect",
                        "effect": {
                            "effect": "minecraft:slowness",
                            "duration": 100,
                            "amplifier": 1,
                            "is_ambient": true,
                            "show_particles": false,
                            "show_icon": true
                        }
                    }
                },
                {
                    "type": "origins:if_else",
                    "condition": {
                        "type": "origins:command",
                        "command": "execute if score @s msmp.veilbound.sun_timer matches 121..180",
                        "comparison": ">=",
                        "compare_to": 1
                    },
                    "if_action": {
                        "type": "origins:apply_effect",
                        "effect": {
                            "effect": "minecraft:slowness",
                            "duration": 100,
                            "amplifier": 2,
                            "is_ambient": true,
                            "show_particles": false,
                            "show_icon": true
                        }
                    }
                },
                {
                    "type": "origins:if_else",
                    "condition": {
                        "type": "origins:command",
                        "command": "execute if score @s msmp.veilbound.sun_timer matches 181..240",
                        "comparison": ">=",
                        "compare_to": 1
                    },
                    "if_action": {
                        "type": "origins:apply_effect",
                        "effect": {
                            "effect": "minecraft:slowness",
                            "duration": 100,
                            "amplifier": 3,
                            "is_ambient": true,
                            "show_particles": false,
                            "show_icon": true
                        }
                    }
                },
                {
                    "type": "origins:if_else",
                    "condition": {
                        "type": "origins:command",
                        "command": "execute if score @s msmp.veilbound.sun_timer matches 240..300",
                        "comparison": ">=",
                        "compare_to": 1
                    },
                    "if_action": {
                        "type": "origins:apply_effect",
                        "effect": {
                            "effect": "minecraft:slowness",
                            "duration": 100,
                            "amplifier": 4,
                            "is_ambient": true,
                            "show_particles": false,
                            "show_icon": true
                        }
                    }
                }
            ]
        }
    },
    "fire": {
        "type": "origins:modify_damage_taken",
        "damage_condition": {
            "type": "origins:fire"
        },
        "modifier": {
            "operation": "multiply_base",
            "value": 3
        }
    }
}