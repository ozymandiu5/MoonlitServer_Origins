{
    "name": "Eyesight",
    "description": "You can tune your eyesight to be able to see in the dark.",
    "badges": [
        {
            "type": "origins:keybind",
            "text": "Active ability, use with %s",
            "sprite": "origins:textures/gui/badge/active.png"
        },
        {
            "type": "origins:tooltip",
            "text": "You can only use your vision for up to 5 minutes.",
            "sprite": "origins:textures/gui/badge/info.png"
        },
        {
            "type": "origins:tooltip",
            "text": "Not using your vision before 5 minutes will slowly recharge what was lost.",
            "sprite": "origins:textures/gui/badge/info.png"
        },
        {
            "type": "origins:tooltip",
            "text": "If you use up all 5 minutes, you'll have to wait for two and a half minutes to recharge!",
            "sprite": "origins:textures/gui/badge/info.png"
        }
    ],
    "type": "origins:multiple",
    "nightvision": {
        "condition": {
            "type": "origins:and",
            "conditions": [
                {
                    "type": "origins:command",
                    "command": "execute if entity @s[tag=msmp_origins.kattzen.nightvision]",
                    "comparison": ">=",
                    "compare_to": 1
                },
                {
                    "type": "origins:resource",
                    "resource": "*:*_energy",
                    "comparison": ">=",
                    "compare_to": 1
                }
            ]
        },
        "type": "origins:action_over_time",
        "interval": 20,
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:apply_effect",
                    "effect": {
                        "effect": "minecraft:night_vision",
                        "duration": 400,
                        "amplifier": 0,
                        "is_ambient": true,
                        "show_particles": false,
                        "show_icon": true
                    }
                },
                {
                    "type": "origins:change_resource",
                    "resource": "*:*_energy",
                    "change": -1,
                    "operation": "add"
                }
            ]
        }
    },
    "toggle": {
        "condition": {
            "type": "origins:or",
            "conditions": [
                {
                    "type": "origins:resource",
                    "resource": "*:*_energy",
                    "comparison": ">=",
                    "compare_to": 1
                },
                {
                    "type": "origins:command",
                    "command": "execute unless entity @s[tag=msmp_origins.kattzen.novision]",
                    "comparison": ">=",
                    "compare_to": 1
                }
            ]
        },
        "type": "origins:active_self",
        "entity_action": {
            "type": "origins:if_else",
            "condition": {
                "type": "origins:command",
                "command": "execute if entity @s[tag=msmp_origins.kattzen.nightvision]",
                "comparison": ">=",
                "compare_to": 1
            },
            "if_action": {
                "type": "origins:and",
                "actions": [
                    {
                        "type": "origins:execute_command",
                        "command": "tag @s remove msmp_origins.kattzen.nightvision"
                    },
                    {
                        "type": "origins:clear_effect",
                        "effect": "minecraft:night_vision"
                    }
                ]
            },
            "else_action": {
                "type": "origins:execute_command",
                "command": "tag @s add msmp_origins.kattzen.nightvision"
            }
        },
        "cooldown": 60,
        "key": "secondary"
    },
    "energy": {
        "type": "origins:resource",
        "min": 0,
        "max": 300,
        "start_value": 0,
        "hud_render": {
            "should_render": true,
            "sprite_location": "origins:textures/gui/community/spiderkolo/resource_bar_02.png",
            "bar_index": 7
        },
        "min_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:execute_command",
                    "command": "tag @s remove msmp_origins.kattzen.nightvision"
                },
                {
                    "type": "origins:execute_command",
                    "command": "tag @s add msmp_origins.kattzen.novision"
                }
            ]
        },
        "max_action": {
            "type": "origins:execute_command",
            "command": "tag @s remove msmp_origins.kattzen.novision"
        }
    },
    "recharge_normal": {
        "condition": {
            "type": "origins:and",
            "conditions": [
                {
                    "type": "origins:resource",
                    "resource": "*:*_energy",
                    "comparison": "<=",
                    "compare_to": 300
                },
                {
                    "type": "origins:command",
                    "command": "execute unless entity @s[tag=msmp_origins.kattzen.nightvision]",
                    "comparison": ">=",
                    "compare_to": 1
                },
                {
                    "type": "origins:command",
                    "command": "execute unless entity @s[tag=msmp_origins.kattzen.novision]",
                    "comparison": ">=",
                    "compare_to": 1
                }
            ]
        },
        "type": "origins:action_over_time",
        "interval": 20,
        "entity_action": {
            "type": "origins:change_resource",
            "resource": "*:*_energy",
            "change": 1,
            "operation": "add"
        }
    },
    "recharge_fast": {
        "condition": {
            "type": "origins:and",
            "conditions": [
                {
                    "type": "origins:resource",
                    "resource": "*:*_energy",
                    "comparison": "<=",
                    "compare_to": 300
                },
                {
                    "type": "origins:command",
                    "command": "execute unless entity @s[tag=msmp_origins.kattzen.nightvision]",
                    "comparison": ">=",
                    "compare_to": 1
                },
                {
                    "type": "origins:command",
                    "command": "execute if entity @s[tag=msmp_origins.kattzen.novision]",
                    "comparison": ">=",
                    "compare_to": 1
                }
            ]
        },
        "type": "origins:action_over_time",
        "interval": 10,
        "entity_action": {
            "type": "origins:change_resource",
            "resource": "*:*_energy",
            "change": 1,
            "operation": "add"
        }
    }
}